      "id": "dialogue_1",
      "type": "dialogue",
      "position": { "x": 80, "y": 80 },
      "data": {
        "character": "Narrator",
        "text": "You awaken in a dark forest. The air is cold and thick with mist. A path splits before you."
      }
    },
    {
      "id": "choice_1",
      "type": "choice",
      "position": { "x": 420, "y": 80 },
      "data": {
        "prompt": "Which path do you take?",
        "choices": [
          { "id": "ch_a1", "text": "The left path, towards the light.", "condition": null },
          { "id": "ch_a2", "text": "The right path, into the shadows.", "condition": null },
          {
            "id": "ch_a3",
            "text": "Use the key you found earlier.",
            "condition": { "variable": "hasKey", "operator": "==", "value": true }
          }
        ]
      }
    },
    {
      "id": "condition_1",
      "type": "condition",
      "position": { "x": 780, "y": 0 },
      "data": {
        "variable": "health",
        "operator": ">",
        "value": 50
      }
    },
    {
      "id": "setvar_1",
      "type": "setVariable",
      "position": { "x": 780, "y": 180 },
      "data": {
        "variable": "hasKey",
        "operation": "set",
        "value": true
      }
    },
    {
      "id": "dialogue_2",
      "type": "dialogue",
      "position": { "x": 1140, "y": 0 },
      "data": {
        "character": "Narrator",
        "text": "Strong enough to fight, you push forward through the light path and emerge into a clearing."
      }
    },
    {
      "id": "dialogue_3",
      "type": "dialogue",
      "position": { "x": 1140, "y": 140 },
      "data": {
        "character": "Narrator",
        "text": "Too weak to continue, you collapse on the forest floor. The mist closes in around you."
      }
    },
    {
      "id": "dialogue_4",
      "type": "dialogue",
      "position": { "x": 1140, "y": 280 },
      "data": {
        "character": "Narrator",
        "text": "In the shadows you find a discarded iron key, glinting faintly in the moonlight."
      }
    }
  ],
